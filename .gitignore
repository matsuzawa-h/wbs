# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Bundled Vue assets inside API (generated from packages/web/dist on publish)
packages/api/public/

# SQLite databases (dev DB lives under packages/api/data/)
**/data/*.db
**/data/*.db-journal
**/data/*.db-wal
**/data/*.db-shm

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Test / coverage
coverage/
.nyc_output/

# Playwright MCP cli artifacts (snapshots/logs)
.playwright-cli/

# Excel exporter runtime artifacts (inspector dumps + test exports)
packages/api/scripts/inspect-out.txt
packages/api/scripts/out.xls
packages/api/scripts/*.xlsx

# Temp
*.tmp
*.temp

