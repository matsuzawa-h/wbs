public-hoist-pattern[]=sass*
public-hoist-pattern[]=@types/*

# node_modules を npm 風のフラット構造で作成する。
# 既定値の "isolated" だとシンボリックリンクで構成されるため、
# pnpm --prod deploy → robocopy で本番へ転送するとリンクが壊れ、
# Cannot find module 'tslib' などのエラーで起動できない。
# hoisted ならどんなコピー手段でも壊れず、本番側で npm install
# 不要 (ネット制限環境でもデプロイ可能)。
node-linker=hoisted
